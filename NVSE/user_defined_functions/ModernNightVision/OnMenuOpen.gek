int	iMenuID

begin Function {iMenuID}

	if eval MenuMode 1
		return
	endif

	SetUIFloatAlt "HudMainMenu\ModernNightVision\_PipBoy" 1
	SetUIFloatGradual "HudMainMenu\ModernNightVision\_AlphaMenu" 100
	SetUIFloatGradual "HudMainMenu\ModernNightVision\_AlphaMenu" 100 (Goo1.AuxVarGetFlt "*SNV_INI" 2) 0.25

end